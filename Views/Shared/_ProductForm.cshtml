@model ProductManagement.Models.ProductViewModel;

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border p-4">

            <h4 class="text-secondary mb-3">@ViewData["Title"]</h4>

            <form asp-controller="Product" asp-action="@(ViewData["FormAction"])" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                @if(ViewData["FormAction"]?.ToString() == "Update")
                {
                    <div class="mb-3">
                        <input asp-for="Id" type="hidden" readonly />
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold small"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="small text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SkuCode" class="form-label fw-bold small"></label>
                    <input asp-for="SkuCode" class="form-control" />
                    <span asp-validation-for="SkuCode" class="small text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold small"></label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="small text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UnitPrice" class="form-label fw-bold small"></label>
                    <input asp-for="UnitPrice" class="form-control" />
                    <span asp-validation-for="UnitPrice" class="small text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="form-label fw-bold small"></label>
                    <select asp-for="Category" class="form-select">
                        <option value="">-- Choose Product Category --</option>
                        <option value="Electronics">Electronics</option>
                        <option value="Accessories">Accessories</option>
                        <option value="Home & Kitchen">Home & Kitchen</option>
                        <option value="Wearables">Wearables</option>
                        <option value="Bags">Bags</option>
                        <option value="Kitchen">Kitchen</option>
                        <option value="Home">Home</option>
                    </select>
                    <span asp-validation-for="Category" class="small text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold small"></label>
                        <input asp-for="ImageUrl" class="form-control" />
                        <span asp-validation-for="ImageUrl" class="small text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>

                    <button type="submit" class="btn btn-success">@ViewData["FormAction"]</button>
                </div>
            </form>

        </div>
    </div>
</div>
